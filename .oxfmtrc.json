{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"ignorePatterns": [],
	"printWidth": 100,
	"tabWidth": 4,
	"useTabs": true,
	"semi": true,
	"singleQuote": true,
	"trailingComma": "all",
	"sortPackageJson": true,
	"jsdoc": {
		"bracketSpacing": true,
		"descriptionWithDot": true,
		"preferCodeFences": true
	}
}
